# Copy to .env and fill in. Never commit the real .env.

# --- Required ---
SPLITWISE_API_KEY=
LUNCHMONEY_ACCESS_TOKEN=
LM_CLEARING_ASSET_ID=

# --- Optional ---
# Exclude-from-totals Lunch Money category used for settle-up payment offsets.
SETTLEMENT_CATEGORY_NAME=Splitwise Settlement
# Run Lunch Money auto-rules at insert so categories you owe get categorized by LM.
APPLY_RULES=true

# REPORT_WEBHOOK=https://hooks.slack.com/services/...
# MY_SPLITWISE_USER_ID=12345      # else derived from get_current_user
# SWLM_DB_PATH=swlm_state.db      # disposable cursor cache; safe to lose
# FIRST_RUN_LOOKBACK_DAYS=90
